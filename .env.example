# Supabase Configuration
# Retrieve these from your Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Supabase Service Role Key (used for admin operations like avatar uploads)
# Retrieve from Supabase Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# TLDraw API Configuration
# Retrieve this from your TLDraw API service dashboard
TLDRAW_API=your-tldraw-api-key

# SendGrid API Key for sending invitation emails
# Retrieve this from your SendGrid Dashboard
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=Zentrox <noreply@yourdomain.com>

# PostHog Analytics Configuration
# Retrieve these from your PostHog project settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=your-posthog-project-token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sync Server (WebSocket for real-time collaboration)
NEXT_PUBLIC_SYNC_SERVER_URL=https://your-sync-server.com

# Base URL for the application (used for invite links, sitemap, etc.)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

